<%- if host && port -%>
<div class="d-flex flex-column gap-3 py-2">
  <div class="d-flex gap-3 justify-content-center">
    <a href="/rnode/<%= host %>/<%= port %>/" target="_blank" class="btn btn-success btn-lg px-4">
      🧬 Open GenoFLU
    </a>
  </div>
  <p class="text-center text-muted small mb-0">
    Add an assembled influenza-A FASTA to a project sample, then Run GenoFLU.
  </p>
</div>
<%- end -%>
