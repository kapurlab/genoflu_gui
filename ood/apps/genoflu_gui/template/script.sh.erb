#!/usr/bin/env bash
# GenoFLU GUI OOD batch_connect script.
# $port (uvicorn) is exported by before.sh.

echo "=== GenoFLU GUI Session Starting ==="
echo "uvicorn:${port}"

# Shared conda env installed at the tool root.
# Falls back to a personal install if the shared env is absent.
SHARED_ENV=/srv/kapurlab/tools/genoflu_gui/env
PERSONAL_ENV=/home/${USER}/miniforge3/envs/genoflu_gui
PERSONAL_BASE_PYTHON=/home/${USER}/miniforge3/bin/python

if [ -d "${SHARED_ENV}" ] && [ -x "${SHARED_ENV}/bin/python" ]; then
  GENO_ENV="${SHARED_ENV}"
  PYTHON="${SHARED_ENV}/bin/python"
elif [ -d "${PERSONAL_ENV}" ]; then
  GENO_ENV="${PERSONAL_ENV}"
  PYTHON="${PERSONAL_ENV}/bin/python"
else
  GENO_ENV=""
  PYTHON="${PERSONAL_BASE_PYTHON}"
fi

# Tool source (shared install only — no per-user fallback for the app itself)
GENO_GUI=/srv/kapurlab/tools/genoflu_gui

# Put the conda env bin on PATH so genoflu.py resolves blastn/makeblastdb from
# the env (not system tools), and so seqkit is found for input QC.
export PATH="${GENO_ENV}/bin:${PATH}"
# PYTHONPATH lets the genoflu bin/ scripts find each other (local imports in bin/)
export PYTHONPATH="${GENO_GUI}/bin:${PYTHONPATH}"

cd "${GENO_GUI}/backend"
echo "Starting uvicorn on port ${port}"
echo "  conda env:  ${GENO_ENV}"
echo "  genoflu_gui:${GENO_GUI}"
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port "${port}" \
    --log-level info
